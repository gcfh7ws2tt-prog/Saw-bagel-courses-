*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Noto Sans TC', sans-serif;
  background: var(--cream);
  color: var(--char);
  overflow-x: hidden;
}

/* ─── STICKY NAV ─── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(30,20,8,0.92);
  backdrop-filter: blur(12px);
  padding: 14px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid rgba(196,149,106,0.15);
  transition: all 0.3s;
}
.nav-brand {
  font-family: 'Noto Serif TC', serif;
  font-size: 13px;
  color: var(--sesame-l);
  letter-spacing: 0.05em;
}
.nav-cta {
  background: var(--sesame);
  color: var(--char);
  font-size: 12px;
  font-weight: 700;
  padding: 8px 22px;
  border-radius: 30px;
  text-decoration: none;
  letter-spacing: 0.05em;
  transition: background 0.2s, transform 0.2s;
}
.nav-cta:hover { background: var(--sesame-d); transform: translateY(-1px); }

/* ─── HERO ─── */
.hero {
  min-height: 100vh;
  background: var(--char);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 120px 24px 80px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 50% 30%, rgba(196,149,106,0.14) 0%, transparent 65%),
    radial-gradient(ellipse 40% 40% at 80% 70%, rgba(196,84,122,0.06) 0%, transparent 60%);
}
.hero-grain {
  position: absolute; inset: 0; pointer-events: none; opacity: 0.35;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.08'/%3E%3C/svg%3E");
}
/* Decorative rings */
.hero-ring {
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(196,149,106,0.1);
}
.r1 { width: 700px; height: 700px; top: -200px; right: -200px; }
.r2 { width: 500px; height: 500px; bottom: -150px; left: -150px; border-color: rgba(196,149,106,0.06); }
.r3 { width: 300px; height: 300px; top: 15%; left: 5%; border-color: rgba(196,149,106,0.08); }

.hero-inner { position: relative; max-width: 760px; }

.hero-eyebrow {
  font-size: 11px;
  letter-spacing: 0.4em;
  color: var(--sesame);
  text-transform: uppercase;
  margin-bottom: 24px;
  opacity: 0;
  animation: fadeUp 0.8s 0.2s forwards;
}
.hero-title {
  font-family: 'Noto Serif TC', serif;
  font-size: clamp(40px, 8vw, 88px);
  font-weight: 900;
  color: #FFF8EE;
  line-height: 1.08;
  margin-bottom: 6px;
  letter-spacing: -0.01em;
  opacity: 0;
  animation: fadeUp 0.9s 0.35s forwards;
}
.hero-title-sub {
  font-family: 'Noto Serif TC', serif;
  font-size: clamp(26px, 4.5vw, 48px);
  font-weight: 700;
  color: var(--sesame);
  margin-bottom: 28px;
  opacity: 0;
  animation: fadeUp 0.9s 0.45s forwards;
}
.hero-desc {
  font-size: clamp(13px, 2vw, 16px);
  color: rgba(232,201,160,0.75);
  line-height: 2;
  max-width: 580px;
  margin: 0 auto 40px;
  opacity: 0;
  animation: fadeUp 0.9s 0.6s forwards;
}
.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
  margin-bottom: 48px;
  opacity: 0;
  animation: fadeUp 0.9s 0.75s forwards;
}
.hbadge {
  background: rgba(196,149,106,0.12);
  border: 1px solid rgba(196,149,106,0.25);
  border-radius: 30px;
  padding: 8px 20px;
  font-size: 12px;
  color: var(--sesame-l);
  letter-spacing: 0.03em;
}
.hero-btn {
  display: inline-block;
  background: var(--sesame);
  color: var(--char);
  font-family: 'Noto Serif TC', serif;
  font-size: 17px;
  font-weight: 700;
  padding: 18px 56px;
  border-radius: 50px;
  text-decoration: none;
  letter-spacing: 0.06em;
  box-shadow: 0 8px 32px rgba(196,149,106,0.35);
  transition: all 0.25s;
  opacity: 0;
  animation: fadeUp 0.9s 0.9s forwards;
}
.hero-btn:hover { background: var(--sesame-d); transform: translateY(-3px); box-shadow: 0 14px 40px rgba(196,149,106,0.45); }
.hero-scroll-hint {
  position: absolute;
  bottom: 32px; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  opacity: 0;
  animation: fadeIn 1s 1.4s forwards;
}
.hero-scroll-hint span { font-size: 9px; letter-spacing: 0.25em; color: rgba(196,149,106,0.4); }
.scroll-bar { width: 1px; height: 44px; background: linear-gradient(to bottom, var(--sesame), transparent); animation: pulse 2s infinite; }

/* ─── QUOTE STRIP ─── */
.quote-strip {
  background: var(--sesame);
  padding: 28px 24px;
  text-align: center;
}
.quote-strip p {
  font-family: 'Noto Serif TC', serif;
  font-size: clamp(14px, 2.2vw, 20px);
  color: var(--char);
  line-height: 1.9;
  max-width: 700px;
  margin: 0 auto;
  font-weight: 500;
}

/* ─── GENERIC SECTION ─── */
.sec {
  padding: 80px 24px;
  max-width: 900px;
  margin: 0 auto;
}
.sec-label {
  font-size: 10px;
  letter-spacing: 0.4em;
  color: var(--sesame);
  text-transform: uppercase;
  margin-bottom: 10px;
  display: block;
}
.sec-title {
  font-family: 'Noto Serif TC', serif;
  font-size: clamp(22px, 4vw, 36px);
  font-weight: 700;
  color: var(--char);
  line-height: 1.3;
  margin-bottom: 8px;
}
.sec-sub {
  font-size: 14px;
  color: var(--mist);
  margin-bottom: 40px;
  line-height: 1.8;
}
.sec-rule {
  width: 40px; height: 2px;
  background: var(--sesame);
  margin-bottom: 40px;
}

/* ─── FLAVOR CARDS ─── */
.flavor-grid { display: grid; gap: 14px; }
.flavor-card {
  border-radius: 16px;
  padding: 24px 28px;
  display: flex;
  gap: 20px;
  align-items: flex-start;
  transition: transform 0.25s, box-shadow 0.25s;
  position: relative;
  overflow: hidden;
}
.flavor-card:hover { transform: translateY(-4px); box-shadow: 0 20px 50px rgba(30,20,8,0.12); }
.fc1 { background: linear-gradient(130deg,#FDE8C0,#FDF0D4); }
.fc2 { background: linear-gradient(130deg,#F9DDE8,#FAE8F2); }
.fc3 { background: linear-gradient(130deg,#D8EED0,#E4F5D8); }
.fc4 { background: linear-gradient(130deg,#CCD8EE,#D8E6F4); }
.fc5 { background: linear-gradient(130deg,#EAD8C0,#F4E8D4); border: 2px dashed rgba(196,149,106,0.5); }

.fc-num {
  font-family: 'Noto Serif TC', serif;
  font-size: 42px;
  font-weight: 900;
  opacity: 0.12;
  line-height: 1;
  flex-shrink: 0;
  color: var(--char);
  width: 56px;
}
.fc-body { flex: 1; }
.fc-tag {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  padding: 3px 12px;
  border-radius: 20px;
  margin-bottom: 10px;
}
.tag-sw { background: rgba(196,84,122,0.12); color: var(--berry); }
.tag-sa { background: rgba(92,128,80,0.12); color: var(--sage); }
.tag-bo { background: rgba(196,149,106,0.18); color: var(--sesame-d); }
.fc-name {
  font-family: 'Noto Serif TC', serif;
  font-size: clamp(16px, 2.5vw, 20px);
  font-weight: 700;
  color: var(--char);
  margin-bottom: 12px;
}
.fc-tags { display: flex; flex-wrap: wrap; gap: 7px; }
.ftag {
  background: rgba(30,20,8,0.07);
  border-radius: 20px;
  padding: 4px 14px;
  font-size: 12px;
  color: var(--bark);
}

/* ─── WHAT YOU LEARN ─── */
.learn-bg { background: var(--warm); }
.learn-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 16px;
}
.lcard {
  background: white;
  border-radius: 14px;
  padding: 28px 24px;
  border: 1px solid rgba(196,149,106,0.18);
  transition: border-color 0.25s, transform 0.25s;
}
.lcard:hover { border-color: var(--sesame); transform: translateY(-3px); }
.lcard-icon { font-size: 30px; margin-bottom: 14px; }
.lcard h3 {
  font-family: 'Noto Serif TC', serif;
  font-size: 15px;
  font-weight: 700;
  color: var(--char);
  margin-bottom: 8px;
}
.lcard p { font-size: 13px; color: var(--smoke); line-height: 1.85; }

/* ─── CURRICULUM ─── */
.cur-bg { background: var(--char); }
.cur-bg .sec-label { color: var(--sesame); }
.cur-bg .sec-title { color: #FFF8EE; }
.cur-bg .sec-sub { color: rgba(232,201,160,0.55); }
.cur-bg .sec-rule { background: var(--sesame); }

.cur-list { display: grid; gap: 12px; }
.cur-item {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(196,149,106,0.12);
  border-radius: 12px;
  padding: 22px 24px;
  display: flex;
  gap: 20px;
  align-items: flex-start;
  transition: background 0.25s;
}
.cur-item:hover { background: rgba(196,149,106,0.07); }
.cur-num {
  font-family: 'Noto Serif TC', serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--sesame);
  line-height: 1;
  flex-shrink: 0;
  width: 40px;
  padding-top: 2px;
}
.cur-title {
  font-size: 16px;
  font-weight: 700;
  color: #FFF8EE;
  margin-bottom: 10px;
}
.cur-chips { display: flex; flex-wrap: wrap; gap: 7px; }
.cchip {
  background: rgba(196,149,106,0.13);
  border-radius: 20px;
  padding: 4px 14px;
  font-size: 12px;
  color: var(--sesame-l);
}

/* ─── WHO ─── */
.who-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
@media(max-width:600px){ .who-grid { grid-template-columns: 1fr; } }
.wcard { border-radius: 14px; padding: 28px 26px; }
.wyes { background: #EBF5E6; border: 1px solid rgba(92,128,80,0.25); }
.wno  { background: #FAF0EE; border: 1px solid rgba(192,96,80,0.18); }
.wcard h3 {
  font-family: 'Noto Serif TC', serif;
  font-size: 15px;
  font-weight: 700;
  margin-bottom: 16px;
}
.wyes h3 { color: var(--sage); }
.wno h3  { color: #A05040; }
.wcard li {
  list-style: none;
  font-size: 13px;
  color: var(--smoke);
  line-height: 1.9;
  padding: 5px 0;
  border-bottom: 1px solid rgba(30,20,8,0.06);
}
.wcard li:last-child { border-bottom: none; }
.wcard li::before { content: '▸  '; color: var(--sesame); }
.who-note {
  grid-column: 1 / -1;
  background: linear-gradient(120deg, #FDE8C0, #FDF0D4);
  border-left: 4px solid var(--sesame);
  border-radius: 0 12px 12px 0;
  padding: 20px 24px;
  font-size: 14px;
  color: var(--char);
  line-height: 1.9;
}
.who-note b { color: var(--bark); font-size: 15px; }

/* ─── INSTRUCTOR ─── */
.inst-bg { background: linear-gradient(160deg, #F5EDE0, var(--cream)); }
.inst-card {
  background: white;
  border-radius: 20px;
  padding: 48px 44px;
  box-shadow: 0 12px 48px rgba(30,20,8,0.08);
  border: 1px solid rgba(196,149,106,0.15);
  max-width: 760px;
  margin: 0 auto;
}
.inst-name {
  font-family: 'Noto Serif TC', serif;
  font-size: 32px;
  font-weight: 900;
  color: var(--char);
  margin-bottom: 6px;
}
.inst-role {
  font-size: 13px;
  color: var(--sesame);
  letter-spacing: 0.08em;
  margin-bottom: 28px;
}
.inst-body { font-size: 15px; color: var(--smoke); line-height: 2.1; }
.inst-body p { margin-bottom: 16px; }
.inst-body p:last-child { margin-bottom: 0; }
.inst-motto {
  margin-top: 28px;
  font-family: 'Noto Serif TC', serif;
  font-size: 17px;
  font-weight: 700;
  color: var(--sesame-d);
  padding-top: 24px;
  border-top: 1px solid rgba(196,149,106,0.2);
}

/* ─── INFO TABLE ─── */
.info-bg { background: var(--char); }
.info-bg .sec-label { color: var(--sesame); }
.info-bg .sec-title { color: #FFF8EE; }
.info-bg .sec-rule { background: var(--sesame); }
.info-table {
  width: 100%;
  border-collapse: collapse;
  max-width: 760px;
  margin: 0 auto;
}
.info-table tr { border-bottom: 1px solid rgba(196,149,106,0.1); transition: background 0.2s; }
.info-table tr:hover { background: rgba(196,149,106,0.05); }
.info-table th {
  text-align: left;
  padding: 18px 12px;
  font-size: 11px;
  font-weight: 700;
  color: var(--sesame);
  letter-spacing: 0.1em;
  width: 130px;
}
.info-table td {
  padding: 18px 12px;
  font-size: 15px;
  color: #FFF8EE;
  font-weight: 300;
}
.price-num {
  font-family: 'Noto Serif TC', serif;
  font-size: 36px;
  font-weight: 900;
  color: var(--sesame);
}

/* ─── CLOSING ─── */
.close-sec {
  background: linear-gradient(160deg, #140C04, var(--char), #140C04);
  padding: 120px 24px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.close-sec::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 55% at 50% 50%, rgba(196,149,106,0.12) 0%, transparent 65%);
}
.close-inner { position: relative; max-width: 640px; margin: 0 auto; }
.close-text {
  font-family: 'Noto Serif TC', serif;
  font-size: clamp(16px, 2.8vw, 24px);
  color: rgba(232,201,160,0.85);
  line-height: 2.2;
  margin-bottom: 52px;
}
.close-text em { font-style: normal; color: var(--sesame); font-weight: 700; }
.close-btn {
  display: inline-block;
  background: var(--sesame);
  color: var(--char);
  font-family: 'Noto Serif TC', serif;
  font-size: 18px;
  font-weight: 700;
  padding: 20px 64px;
  border-radius: 50px;
  text-decoration: none;
  letter-spacing: 0.06em;
  box-shadow: 0 10px 36px rgba(196,149,106,0.4);
  transition: all 0.25s;
}
.close-btn:hover { background: var(--sesame-d); transform: translateY(-3px); box-shadow: 0 16px 48px rgba(196,149,106,0.5); }
.close-note { margin-top: 18px; font-size: 12px; color: rgba(196,149,106,0.4); letter-spacing: 0.15em; }

/* ─── FOOTER ─── */
footer {
  background: #0A0604;
  padding: 24px;
  text-align: center;
}
footer p { font-size: 11px; color: rgba(196,149,106,0.3); letter-spacing: 0.18em; }

/* ─── SCROLL REVEAL ─── */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ─── ANIMATIONS ─── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; } to { opacity: 1; }
}
@keyframes pulse {
  0%,100% { opacity: 0.3; } 50% { opacity: 1; }
}

/* ─── RESPONSIVE ─── */
@media(max-width:640px){
  .flavor-card { flex-direction: column; gap: 10px; }
  .fc-num { font-size: 28px; width: auto; }
  .inst-card { padding: 28px 20px; }
  nav { padding: 12px 16px; }
}
